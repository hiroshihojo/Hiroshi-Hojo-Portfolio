---
interface Props {
  href: string;
  title: string;
  summary: string;
  method: string;
  status: string;
  index?: string;
}

const { href, title, summary, method, status, index } = Astro.props;
---

<a class="card" href={href}>
  <div class="card-row">
    {index && <span class="card-index">{index}</span>}
    <div class="card-body">
      <div class="card-top">
        <span class="tag">
          <span class="status-dot" data-status={status}></span>
          {method}
        </span>
      </div>
      <h3>{title}</h3>
      <p>{summary}</p>
    </div>
    <span class="card-arrow" aria-hidden="true">&rarr;</span>
  </div>
</a>

<style>
  .card {
    display: block;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
    color: var(--ink);
    border-bottom: none;
  }

  .card:hover {
    border-bottom: none;
  }

  .card-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: start;
  }

  .card-index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-tertiary);
    padding-top: 0.2rem;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card h3 {
    font-size: 1.2rem;
    margin: 0;
    transition: opacity 150ms ease;
  }

  .card p {
    margin: 0;
    font-size: 0.92rem;
    max-width: 60ch;
  }

  .card-arrow {
    font-size: 1.1rem;
    color: var(--text-tertiary);
    transition: transform 180ms ease, color 180ms ease;
    padding-top: 0.2rem;
  }

  .card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  .card:hover h3 {
    opacity: 0.65;
  }

  @media (max-width: 620px) {
    .card-row {
      grid-template-columns: auto 1fr;
    }
    .card-arrow {
      display: none;
    }
  }
</style>
