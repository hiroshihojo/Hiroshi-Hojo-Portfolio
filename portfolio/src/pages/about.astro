---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const skills = [
  { group: "Computation", items: ["Python", "pymatgen", "Quantum ESPRESSO", "NumPy / SciPy"] },
  { group: "Physics foundations", items: ["Solid-state physics", "Quantum mechanics", "Statistical mechanics"] },
  { group: "Data", items: ["Materials Project API", "scikit-learn", "pandas"] },
  { group: "In progress", items: ["XRD/SEM interpretation", "Cleanroom / fabrication basics"] },
];
---

<Layout title="About — Hiroshi Hojo">
  <section class="wrap about">
    <p class="eyebrow">About</p>
    <h1>Hiroshi Hojo</h1>
    <p class="intro">
      I'm a graduating physics major heading into a materials engineering
      master's, focused on semiconductor and electronic materials. This
      site documents the projects I've built to bridge physics theory and
      materials engineering practice — replace this paragraph with your
      own two or three sentence story.
    </p>

    <div class="skills">
      {
        skills.map((s) => (
          <div class="skill-group">
            <h2>{s.group}</h2>
            <ul>
              {s.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="links">
      <a class="btn" href="/your-cv.pdf">Download CV &rarr;</a>
      <a class="btn btn-ghost" href={`${base}projects/`}>See projects</a>
    </div>
  </section>
</Layout>

<style>
  .about {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    max-width: 680px;
  }

  .about h1 {
    font-size: clamp(2rem, 3.8vw, 2.6rem);
    margin: 0.3em 0 0.6em;
  }

  .intro {
    font-size: 1.05rem;
  }

  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .skill-group h2 {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin-bottom: 0.9rem;
    font-weight: 700;
  }

  .skill-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .skill-group li {
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    font-size: 0.92rem;
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .btn {
    font-size: 0.9rem;
    padding: 0.4em 0;
    border-bottom: 1px solid var(--ink);
    color: var(--ink);
  }

  .btn-ghost {
    color: var(--text-secondary);
    border-bottom-color: var(--line);
  }
</style>
