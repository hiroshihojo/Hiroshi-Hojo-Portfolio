---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const allProjects = await getCollection("projects");
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Hiroshi Hojo | 北條宏志">
  <section class="hero wrap">
    <div class="hero-main">
      <h1>
        Hiroshi M. Hojo　<br> (北條宏志)
      </h1>
      <h2>BS Physics
      </h2>
      <p class="hero-sub">
        Graduating physics major at the University of the Philippines Diliman, 
        where I spent two years in the Condensed Matter Physics Laboratory's 
        semiconductor group researching on the material fabrication and characterization. That work gave me hands-on experience with 
        Porous Silicon fabrication, Zinc Oxide deposition, photoluminescence spectroscopy, 
        and a understanding of how lab-scale physics connects to device performance. 
        Alongside that, I've built independent projects, computational and experimental, that apply 
        physics to materials-selection and materials-design problems, including **. 
        I'm now looking to formalize that trajectory in a materials engineering master's, with the goal of 
        enriching my knowledge in energy materials and material design.
      </p>
      <div class="hero-actions">
        <a class="btn" href={`${base}projects/`}>View projects &rarr;</a>
        <a class="btn btn-ghost" href={`${base}about/`}>About</a>
      </div>
    </div>

    <figure class="hero-photo">
      <img src={`${base}images/hiroshi-hojo.jpg`} alt="Hiroshi Hojo" />
      <figcaption> </figcaption>
    </figure>
  </section>

  <section class="wrap section">
    <div class="section-head">
      <h2>Featured projects</h2>
      <a class="see-all" href={`${base}projects/`}>All projects &rarr;</a>
    </div>
    <div class="list">
      {
        featured.map((project, i) => (
          <ProjectCard
            href={`${base}projects/${project.id}/`}
            title={project.data.title}
            summary={project.data.summary}
            method={project.data.method}
            status={project.data.status}
            index={String(i + 1).padStart(2, "0")}
          />
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .hero-photo {
    margin: 0;
    border: 1px solid var(--line);
  }

  .hero-photo {
    margin: 0;
    background: #fff;
    padding: 0.9rem 0.9rem 0;
    box-shadow: 0 6px 18px rgba(20, 20, 20, 0.12);
    transform: rotate(-2deg);
    max-width: 320px;
    justify-self: end;
  }

  .hero-photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
    display: block;
  }

  .hero-photo figcaption {
    padding: 0.9rem 0.3rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2rem, 4.2vw, 3.1rem);
    margin: 0.4em 0 0.6em;
    max-width: 16ch;
  }

  .hero-sub {
    max-width: 46ch;
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 1.75rem;
  }

  .btn {
    font-size: 0.9rem;
    padding: 0.75em 0;
    border-bottom: 1px solid var(--ink);
    color: var(--ink);
  }

  .btn-ghost {
    color: var(--text-secondary);
    border-bottom-color: var(--line);
  }

  .title-block {
    border: 1px solid var(--ink);
    padding: 1.25rem;
    font-family: var(--font-mono);
    margin-top: 0.3rem;
  }

  .tb-name {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    padding-bottom: 0.85rem;
    margin-bottom: 0.85rem;
    border-bottom: 1px solid var(--line);
  }

  .tb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1rem;
  }

  .tb-label {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin-bottom: 0.25rem;
  }

  .tb-value {
    display: block;
    font-size: 0.82rem;
    color: var(--ink);
  }

  .section {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .section-head h2 {
    font-size: 1.4rem;
    margin: 0;
  }

  .see-all {
    font-size: 0.85rem;
    color: var(--text-secondary);
    border-bottom-color: var(--line);
  }

  .list {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
