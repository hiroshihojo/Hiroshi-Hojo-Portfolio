---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-inner">
    <p class="footer-links">
      <a href="mailto:hiroshi.hojo@example.com">Email</a>
      <span aria-hidden="true">&middot;</span>
      <a href="https://linkedin.com/in/hiroshihojo" target="_blank" rel="noreferrer">LinkedIn</a>
    </p>
    <p class="footer-year">&copy; {year} Hiroshi Hojo</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding: 2rem var(--edge);
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .footer-note,
  .footer-year {
    margin: 0;
  }

  .footer-links {
    margin: 0;
    display: flex;
    gap: 0.6rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    border-bottom: 1px solid transparent;
  }

  .footer-links a:hover {
    color: var(--ink);
    border-bottom-color: var(--line);
  }
</style>
