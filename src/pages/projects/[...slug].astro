---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${project.data.title} — Your Name`} description={project.data.summary}>
  <article class="wrap article">
    <a class="back" href={`${base}projects/`}>&larr; All projects</a>

    <header class="article-head">
      <span class="tag">
        <span class="status-dot" data-status={project.data.status}></span>
        {project.data.method}
      </span>
      <h1>{project.data.title}</h1>
      <p class="summary">{project.data.summary}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article {
    padding-top: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    max-width: 720px;
  }

  .back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    border-bottom-color: var(--line);
  }

  .article-head {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .article-head h1 {
    font-size: clamp(1.7rem, 3.4vw, 2.3rem);
    margin: 0.6em 0 0.5em;
  }

  .summary {
    font-size: 1.05rem;
    margin: 0;
  }

  .prose :global(h2) {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 2.5rem;
    color: var(--ink);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .prose :global(p) {
    color: var(--text-secondary);
  }

  .prose :global(ul) {
    color: var(--text-secondary);
    padding-left: 1.2rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(img) {
    border: 1px solid var(--line);
    margin: 1.25rem 0;
  }

  .prose :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
</style>
