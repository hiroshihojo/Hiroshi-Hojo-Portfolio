---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout title="Projects — Hiroshi Hojo">
  <section class="wrap header">
    <p class="eyebrow">Project log</p>
    <h1>Projects</h1>
    <p class="lede">
      Ordered from the physics thesis this work grew out of through to
      applied, device-oriented studies. Each entry states the method, the
      result, and what it demonstrates for materials engineering
      specifically.
    </p>
  </section>

  <section class="wrap list-wrap">
    <div class="list">
      {
        allProjects.map((project, i) => (
          <ProjectCard
            href={`${base}projects/${project.id}/`}
            title={project.data.title}
            summary={project.data.summary}
            method={project.data.method}
            status={project.data.status}
            index={String(i + 1).padStart(2, "0")}
          />
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .header {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 2.5rem;
    max-width: 640px;
  }

  .header h1 {
    font-size: clamp(2rem, 3.8vw, 2.6rem);
    margin: 0.3em 0 0.5em;
  }

  .lede {
    font-size: 1rem;
  }

  .list-wrap {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .list {
    display: flex;
    flex-direction: column;
  }
</style>
